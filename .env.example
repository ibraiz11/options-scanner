# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. `.env.example` is committed as documentation.
#
# Get free Alpaca paper keys at https://alpaca.markets — make sure the
# dashboard's environment toggle is set to "Paper Trading" before clicking
# "Generate New Key" or the keys will return 401 against paper-api.

ALPACA_API_KEY=PK_paste_your_key_here
ALPACA_API_SECRET=paste_your_40_char_secret_here

# Optional: start the server in Tiny mode (for accounts under $1k).
# Default is "standard" if unset.
# TRADING_MODE=tiny

# Optional: tracing verbosity. "info" is fine for normal runs;
# "debug" shows scheduler ticks and skipped market-closed checks.
# RUST_LOG=info
